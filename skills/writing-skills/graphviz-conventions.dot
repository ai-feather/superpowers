digraph STYLE_GUIDE {
    // 我们的过程 DSL 的风格指南，本身用该 DSL 写成

    // 节点类型示例及其形状
    subgraph cluster_node_types {
        label="节点类型与形状";

        // 问题用菱形
        "这是一个问题吗？" [shape=diamond];

        // 动作用方框（默认）
        "执行一个动作" [shape=box];

        // 命令用纯文本
        "git commit -m 'msg'" [shape=plaintext];

        // 状态用椭圆
        "当前状态" [shape=ellipse];

        // 警告用八边形
        "停止：严重警告" [shape=octagon, style=filled, fillcolor=red, fontcolor=white];

        // 入口/出口用双圆
        "流程开始" [shape=doublecircle];
        "流程完成" [shape=doublecircle];

        // 每种的示例
        "测试通过了吗？" [shape=diamond];
        "先写测试" [shape=box];
        "npm test" [shape=plaintext];
        "我卡住了" [shape=ellipse];
        "绝不用 git add -A" [shape=octagon, style=filled, fillcolor=red, fontcolor=white];
    }

    // 边的命名约定
    subgraph cluster_edge_types {
        label="边的标签";

        "二选一决定？" [shape=diamond];
        "是 的分支" [shape=box];
        "否 的分支" [shape=box];

        "二选一决定？" -> "是 的分支" [label="是"];
        "二选一决定？" -> "否 的分支" [label="否"];

        "多选一？" [shape=diamond];
        "选项 A" [shape=box];
        "选项 B" [shape=box];
        "选项 C" [shape=box];

        "多选一？" -> "选项 A" [label="条件 A"];
        "多选一？" -> "选项 B" [label="条件 B"];
        "多选一？" -> "选项 C" [label="其他情况"];

        "流程 A 完成" [shape=doublecircle];
        "流程 B 开始" [shape=doublecircle];

        "流程 A 完成" -> "流程 B 开始" [label="触发", style=dotted];
    }

    // 命名模式
    subgraph cluster_naming_patterns {
        label="命名模式";

        // 问题以 ? 结尾
        "我应该做 X 吗？";
        "这能是 Y 吗？";
        "Z 为真吗？";
        "我已经做了 W 吗？";

        // 动作以动词开头
        "写测试";
        "搜索模式";
        "提交改动";
        "请求帮助";

        // 命令是字面量
        "grep -r 'pattern' .";
        "git status";
        "npm run build";

        // 状态描述处境
        "测试失败中";
        "构建完成";
        "卡在错误上";
    }

    // 过程结构模板
    subgraph cluster_structure {
        label="过程结构模板";

        "触发：某事发生" [shape=ellipse];
        "初始检查？" [shape=diamond];
        "主要动作" [shape=box];
        "git status" [shape=plaintext];
        "另一个检查？" [shape=diamond];
        "替代动作" [shape=box];
        "停止：不要这样做" [shape=octagon, style=filled, fillcolor=red, fontcolor=white];
        "流程完成" [shape=doublecircle];

        "触发：某事发生" -> "初始检查？";
        "初始检查？" -> "主要动作" [label="是"];
        "初始检查？" -> "替代动作" [label="否"];
        "主要动作" -> "git status";
        "git status" -> "另一个检查？";
        "另一个检查？" -> "流程完成" [label="ok"];
        "另一个检查？" -> "停止：不要这样做" [label="有问题"];
        "替代动作" -> "流程完成";
    }

    // 何时用哪种形状
    subgraph cluster_shape_rules {
        label="何时使用每种形状";

        "选择一个形状" [shape=ellipse];

        "它是一个决定吗？" [shape=diamond];
        "用菱形" [shape=diamond, style=filled, fillcolor=lightblue];

        "它是一个命令吗？" [shape=diamond];
        "用纯文本" [shape=plaintext, style=filled, fillcolor=lightgray];

        "它是一个警告吗？" [shape=diamond];
        "用八边形" [shape=octagon, style=filled, fillcolor=pink];

        "它是入口/出口吗？" [shape=diamond];
        "用双圆" [shape=doublecircle, style=filled, fillcolor=lightgreen];

        "它是一个状态吗？" [shape=diamond];
        "用椭圆" [shape=ellipse, style=filled, fillcolor=lightyellow];

        "默认：用方框" [shape=box, style=filled, fillcolor=lightcyan];

        "选择一个形状" -> "它是一个决定吗？";
        "它是一个决定吗？" -> "用菱形" [label="是"];
        "它是一个决定吗？" -> "它是一个命令吗？" [label="否"];
        "它是一个命令吗？" -> "用纯文本" [label="是"];
        "它是一个命令吗？" -> "它是一个警告吗？" [label="否"];
        "它是一个警告吗？" -> "用八边形" [label="是"];
        "它是一个警告吗？" -> "它是入口/出口吗？" [label="否"];
        "它是入口/出口吗？" -> "用双圆" [label="是"];
        "它是入口/出口吗？" -> "它是一个状态吗？" [label="否"];
        "它是一个状态吗？" -> "用椭圆" [label="是"];
        "它是一个状态吗？" -> "默认：用方框" [label="否"];
    }

    // 好与坏的示例
    subgraph cluster_examples {
        label="好与坏的示例";

        // 好：具体且形状正确
        "测试失败" [shape=ellipse];
        "读错误信息" [shape=box];
        "能复现吗？" [shape=diamond];
        "git diff HEAD~1" [shape=plaintext];
        "绝不忽略错误" [shape=octagon, style=filled, fillcolor=red, fontcolor=white];

        "测试失败" -> "读错误信息";
        "读错误信息" -> "能复现吗？";
        "能复现吗？" -> "git diff HEAD~1" [label="是"];

        // 坏：含糊且形状错误
        bad_1 [label="某个东西错了", shape=box];  // 应为椭圆（状态）
        bad_2 [label="修好它", shape=box];  // 太含糊
        bad_3 [label="检查", shape=box];  // 应为菱形
        bad_4 [label="运行命令", shape=box];  // 应为带真实命令的纯文本

        bad_1 -> bad_2;
        bad_2 -> bad_3;
        bad_3 -> bad_4;
    }
}